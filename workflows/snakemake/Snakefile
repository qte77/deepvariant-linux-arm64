"""
DeepVariant ARM64 — Snakemake workflow

Runs the full DeepVariant pipeline on ARM64 Linux using the pre-built
Docker image. Supports single-sample and batch WGS/WES.

Usage:
  # Single sample
  snakemake --cores 16 --use-singularity \
    --config bam=/data/sample.bam ref=/data/GRCh38.fasta

  # Batch mode (sample sheet)
  snakemake --cores 16 --use-singularity \
    --configfile config.yaml

  # Docker instead of Singularity
  snakemake --cores 16 --use-singularity=false \
    --config bam=/data/sample.bam ref=/data/GRCh38.fasta container=docker
"""

import csv
from pathlib import Path


# ── Configuration ────────────────────────────────────────────────────────
configfile: "config.yaml"

IMAGE = config.get("image", "ghcr.io/antomicblitz/deepvariant-arm64:v1.9.0-arm64.5")
REF = config["ref"]
MODEL_TYPE = config.get("model_type", "WGS")
REGIONS = config.get("regions", "")
BATCH_SIZE = config.get("batch_size", 256)
NUM_SHARDS = config.get("num_shards", workflow.cores)
OUTDIR = config.get("outdir", "results")
DOCKER_MEM = config.get("memory", "28g")

# Build sample dict: {sample_id: {"bam": path, "bai": path}}
SAMPLES = {}
if "input" in config:
    with open(config["input"]) as f:
        for row in csv.DictReader(f):
            SAMPLES[row["sample"]] = {
                "bam": row["bam"],
                "bai": row.get("bai", row["bam"] + ".bai"),
            }
elif "bam" in config:
    name = Path(config["bam"]).stem.replace(".dedup", "").replace(".sorted", "")
    SAMPLES[name] = {
        "bam": config["bam"],
        "bai": config.get("bai", config["bam"] + ".bai"),
    }
else:
    raise ValueError("Provide either 'bam' or 'input' (CSV sample sheet) in config")


# ── Rules ────────────────────────────────────────────────────────────────
rule all:
    input:
        expand(f"{OUTDIR}/{{sample}}/{{sample}}.vcf.gz", sample=SAMPLES.keys()),


rule deepvariant:
    input:
        bam=lambda wc: SAMPLES[wc.sample]["bam"],
        bai=lambda wc: SAMPLES[wc.sample]["bai"],
        ref=REF,
        ref_idx=REF + ".fai",
    output:
        vcf=f"{OUTDIR}/{{sample}}/{{sample}}.vcf.gz",
        gvcf=f"{OUTDIR}/{{sample}}/{{sample}}.g.vcf.gz",
        report=f"{OUTDIR}/{{sample}}/{{sample}}.visual_report.html",
    params:
        region_arg=f"--regions {REGIONS}" if REGIONS else "",
        model_type=MODEL_TYPE,
        batch_size=BATCH_SIZE,
        num_shards=NUM_SHARDS,
        intermediate=f"{OUTDIR}/{{sample}}/intermediate",
    threads: workflow.cores
    log:
        f"{OUTDIR}/{{sample}}/deepvariant.log",
    shell:
        """
        docker run --rm \
            --memory {DOCKER_MEM} \
            -e DV_AUTOCONFIG=1 -e DV_USE_JEMALLOC=1 \
            -v $(dirname {input.ref}):/ref:ro \
            -v $(dirname {input.bam}):/bam:ro \
            -v $(realpath {OUTDIR}/{wildcards.sample}):/output \
            {IMAGE} \
            /opt/deepvariant/bin/run_deepvariant \
                --model_type={params.model_type} \
                --ref=/ref/$(basename {input.ref}) \
                --reads=/bam/$(basename {input.bam}) \
                --output_vcf=/output/{wildcards.sample}.vcf.gz \
                --output_gvcf=/output/{wildcards.sample}.g.vcf.gz \
                --num_shards={params.num_shards} \
                --intermediate_results_dir=/output/intermediate \
                --call_variants_extra_args="--batch_size={params.batch_size}" \
                {params.region_arg} \
            2>&1 | tee {log}
        """
