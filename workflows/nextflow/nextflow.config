/*
 * DeepVariant ARM64 — Nextflow configuration
 *
 * Profiles:
 *   -profile docker       Local Docker (default)
 *   -profile arm64        ARM64 optimized (auto-selects backend)
 *   -profile oracle_a1    Oracle A1 cost-optimized ($0.80/genome)
 *   -profile hetzner      Hetzner CAX shared vCPU ($0.33/genome)
 *   -profile graviton     AWS Graviton3/4 (BF16 when available)
 *   -profile test         Quick validation on chr20
 */

// ── Default parameters ──────────────────────────────────────────────────
params {
    bam        = null
    input      = null
    ref        = null
    model_type = 'WGS'
    regions    = null
    outdir     = 'results'
    num_shards = 0       // 0 = auto (nproc)
    batch_size = 256
    memory     = '28g'
}

// ── Process defaults ────────────────────────────────────────────────────
process {
    withName: 'DEEPVARIANT' {
        cpus   = { Math.min(16, Runtime.runtime.availableProcessors()) }
        memory = '28 GB'
        time   = '12h'
    }
}

// ── Profiles ────────────────────────────────────────────────────────────
profiles {

    docker {
        docker.enabled = true
        docker.runOptions = "--memory ${params.memory}"
        process.container = 'ghcr.io/antomicblitz/deepvariant-arm64:v1.9.0-arm64.6'
    }

    arm64 {
        docker.enabled = true
        docker.runOptions = "--memory ${params.memory} -e DV_AUTOCONFIG=1 -e DV_USE_JEMALLOC=1"
        process.container = 'ghcr.io/antomicblitz/deepvariant-arm64:v1.9.0-arm64.6'
    }

    graviton {
        docker.enabled = true
        docker.runOptions = "--memory ${params.memory} -e DV_AUTOCONFIG=1 -e DV_USE_JEMALLOC=1"
        process.container = 'ghcr.io/antomicblitz/deepvariant-arm64:v1.9.0-arm64.6'
        process {
            withName: 'DEEPVARIANT' {
                cpus   = 16
                memory = '28 GB'
            }
        }
    }

    oracle_a1 {
        docker.enabled = true
        docker.runOptions = "--memory ${params.memory} -e DV_AUTOCONFIG=1 -e DV_USE_JEMALLOC=1"
        process.container = 'ghcr.io/antomicblitz/deepvariant-arm64:v1.9.0-arm64.6'
        process {
            withName: 'DEEPVARIANT' {
                cpus   = 16
                memory = '28 GB'
            }
        }
    }

    hetzner {
        docker.enabled = true
        docker.runOptions = "--memory ${params.memory} -e DV_AUTOCONFIG=1 -e DV_USE_JEMALLOC=1"
        process.container = 'ghcr.io/antomicblitz/deepvariant-arm64:v1.9.0-arm64.6'
        process {
            withName: 'DEEPVARIANT' {
                cpus   = 16
                memory = '28 GB'
            }
        }
    }

    test {
        params.regions    = 'chr20'
        params.model_type = 'WGS'
    }
}

// ── Reports ─────────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/timeline.html"
}

report {
    enabled = true
    file    = "${params.outdir}/report.html"
}

// ── Manifest ────────────────────────────────────────────────────────────
manifest {
    name            = 'deepvariant-arm64'
    author          = 'antomicblitz'
    description     = 'DeepVariant variant calling on ARM64 Linux'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04'
    version         = '1.9.0-arm64.6'
}
